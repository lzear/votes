{
  "name": "votes",
  "version": "3.0.0",
  "description": "Implementation of some [electoral systems](https://en.wikipedia.org/wiki/Electoral_system)",
  "keywords": [
    "votes",
    "condorcet",
    "voting-systems",
    "elections"
  ],
  "homepage": "https://github.com/lzear/votes",
  "bugs": {
    "url": "https://github.com/lzear/votes/issues"
  },
  "repository": "lzear/votes",
  "license": "MIT",
  "author": "lzear",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "typings": "dist/index.d.ts",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsup",
    "build-docs": "cp ../README.md . && yarn typedoc",
    "lint": "eslint .",
    "release": "cp ../README.md . && yarn run build",
    "test": "vitest",
    "test-prod": "yarn run test && yarn run build",
    "typecheck": "tsc --noEmit",
    "typedoc": "npx typedoc src/index.ts --tsconfig tsconfig.typedoc.json"
  },
  "dependencies": {
    "lodash-es": "^4"
  },
  "devDependencies": {
    "@types/lodash-es": "^4",
    "@types/node": "^25",
    "@vitest/coverage-v8": "^4",
    "rimraf": "^6",
    "tsup": "^8",
    "typedoc": "^0.28",
    "typescript": "6.0.3",
    "vitest": "^4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
