{
  "name": "votes",
  "version": "3.0.0",
  "description": "Implementation of some [electoral systems](https://en.wikipedia.org/wiki/Electoral_system)",
  "keywords": [
    "votes",
    "condorcet",
    "voting-systems",
    "elections"
  ],
  "homepage": "https://github.com/lzear/votes",
  "bugs": {
    "url": "https://github.com/lzear/votes/issues"
  },
  "repository": "lzear/votes",
  "license": "MIT",
  "author": "lzear",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "typings": "dist/index.d.ts",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsup",
    "build-docs": "cp ../README.md . && yarn typedoc",
    "lint": "eslint .",
    "release": "cp ../README.md . && yarn run build",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage --runInBand --detectOpenHandles --forceExit",
    "test-prod": "yarn run test && yarn run build",
    "typecheck": "tsc --noEmit",
    "typedoc": "npx typedoc src/index.ts --tsconfig tsconfig.typedoc.json"
  },
  "dependencies": {
    "javascript-lp-solver": "0.4.15",
    "lodash-es": "^4"
  },
  "peerDependencies": {
    "javascript-lp-solver": ">=0.4.0"
  },
  "devDependencies": {
    "@types/jest": "^30",
    "@types/lodash": "^4",
    "@types/lodash-es": "^4",
    "@types/node": "^25",
    "@types/shelljs": "^0.10",
    "dotenv": "^17",
    "jest": "^30",
    "microbundle": "^0.15",
    "rimraf": "^6",
    "shelljs": "^0.10",
    "travis-deploy-once": "^5",
    "ts-jest": "^29",
    "ts-node": "^10",
    "tsconfig": "*",
    "tslib": "^2",
    "tsup": "^8",
    "typedoc": "^0.28",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
